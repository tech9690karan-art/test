Tabs.Main:Section({ Title = "Auto Feed", Icon = "utensils" })

Tabs.Main:Dropdown({
    Title = "Select Food",
    Desc = "Choose the food",
    Values = alimentos,
    Value = selectedFood,
    Multi = true,
    AllowNone = true,
    Callback = function(value)
        selectedFood = value
    end
})

Tabs.Main:Input({
    Title = "Feed Amount",
    Desc = "Eat when hunger reaches this %",
    Value = tostring(hungerThreshold),
    Placeholder = "Ex: 50",
    Numeric = true,
    Callback = function(value)
        local n = tonumber(value)
        if n then
            hungerThreshold = math.clamp(n, 0, 100)
        end
    end
})

-- ============================================
-- MAIN AUTO FEED TOGGLE - FIXED
-- ============================================

Tabs.Main:Toggle({
    Title = "Auto Feed",
    Value = false,
    Callback = function(state)
        autoFeedToggle = state
        
        if state then
            -- Check if any food is selected
            if #selectedFood == 0 then
                WindUI:Notify({
                    Title = "⚠️ No Food Selected",
                    Content = "Please select food from dropdown first!",
                    Duration = 3
                })
                autoFeedToggle = false
                task.wait(0.1)
                Tabs.Main:Find("Auto Feed"):SetValue(false)
                return
            end
            
            WindUI:Notify({
                Title = "🍖 Auto Feed Started",
                Content = "Will eat when hunger drops below " .. hungerThreshold .. "%",
                Duration = 3
            })
            
            -- Start auto feed loop
            task.spawn(function()
                local lastNotification = 0 -- Prevent notification spam
                
                while autoFeedToggle do
                    task.wait(0.1) -- Check every 100ms
                    
                    -- Get current hunger
                    local currentHunger = ghn()
                    
                    -- Check if any selected food exists
                    local foodExists = false
                    local availableFoods = {}
                    
                    for _, foodName in ipairs(selectedFood) do
                        local count = wiki(foodName)
                        if count > 0 then
                            foodExists = true
                            table.insert(availableFoods, foodName)
                        end
                    end
                    
                    -- If no food exists, stop auto feed
                    if not foodExists then
                        autoFeedToggle = false
                        task.wait(0.1)
                        Tabs.Main:Find("Auto Feed"):SetValue(false)
                        
                        WindUI:Notify({
                            Title = "❌ Auto Feed Stopped",
                            Content = "No selected food found!",
                            Duration = 5
                        })
                        break
                    end
                    
                    -- If hungry, eat food
                    if currentHunger <= hungerThreshold then
                        -- Try to eat each available food
                        local ate = false
                        for _, foodName in ipairs(availableFoods) do
                            if feed(foodName) then
                                ate = true
                                
                                -- Show notification every 5 seconds max
                                local currentTime = tick()
                                if currentTime - lastNotification > 5 then
                                    WindUI:Notify({
                                        Title = "🍖 Eating Food",
                                        Content = "Ate: " .. foodName .. " | Hunger: " .. currentHunger .. "%",
                                        Duration = 2
                                    })
                                    lastNotification = currentTime
                                end
                                break
                            end
                        end
                        
                        if not ate then
                            -- Failed to eat despite having food (rare edge case)
                            task.wait(0.5) -- Wait a bit before retry
                        end
                    end
                end
                
                print("Auto Feed loop ended")
            end)
        else
            -- Toggle turned off
            WindUI:Notify({
                Title = "⏹️ Auto Feed Disabled",
                Content = "Auto feed has been stopped",
                Duration = 2
            })
        end
    end
})

