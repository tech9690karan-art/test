-- Function for bringing items
local function BringItem(cframe, promptPath, itemName)
    local character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local root = character:FindFirstChild("HumanoidRootPart")
    if not root then
        WindUI:Notify({
            Title = "❌ Error",
            Content = "Character not found",
            Duration = 2,
            Icon = "alert-circle",
        })
        return
    end
    
    -- Save initial position
    local initialCFrame = root.CFrame
    
    -- Teleport to item
    root.CFrame = cframe
    task.wait(0.5)
    
    -- Find and fire prompt
    local success, prompt = pcall(function()
        return Workspace:WaitForChild(promptPath[1], 3):WaitForChild(promptPath[2], 3):WaitForChild(promptPath[3], 3)
    end)
    
    if success and prompt then
        fireproximityprompt(prompt)
        
        WindUI:Notify({
            Title = "✅ " .. itemName .. " Collected",
            Content = "Item brought successfully",
            Duration = 2,
            Icon = "check",
        })
    else
        WindUI:Notify({
            Title = "❌ Failed",
            Content = "Could not find " .. itemName,
            Duration = 2,
            Icon = "alert-circle",
        })
    end
    
    task.wait(0.5)
    
    -- Teleport back
    root.CFrame = initialCFrame
end

