local function FindItemPrompt(itemName, targetCFrame)
    local closestPrompt = nil
    local closestDistance = math.huge

    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("Folder") and obj.Name == "Items" then
            local item = obj:FindFirstChild(itemName)
            if item then
                local pp = item:FindFirstChild("PP")
                if pp then
                    local distance = (pp.Parent:GetPivot().Position - targetCFrame.Position).Magnitude

                    if distance < closestDistance then
                        closestDistance = distance
                        closestPrompt = pp
                    end
                end
            end
        end
    end

    return closestPrompt
end

-- Function to teleport, fire prompt, and return
local function bringItem(targetCFrame, itemName)
    local character = LocalPlayer.Character
    if not character then
        WindUI:Notify({
            Title = "Error",
            Content = "Character not found",
            Duration = 3,
            Icon = "alert-triangle",
        })
        return
    end

    local root = character:FindFirstChild("HumanoidRootPart")
    if not root then
        WindUI:Notify({
            Title = "Error",
            Content = "HumanoidRootPart not found",
            Duration = 3,
            Icon = "alert-triangle",
        })
        return
    end

    local prompt = FindItemPrompt(itemName, targetCFrame)

    if not prompt then
        warn("❌ Prompt not found:", itemName)
        return
    end

    -- Save initial position
    local initialCFrame = root.CFrame

    -- Teleport to target
    root.CFrame = targetCFrame
    task.wait(0.5)

    -- Fire prompt
    fireproximityprompt(prompt)
    print("✅ Prompt fired:", prompt:GetFullName())

    task.wait(0.5)

    -- Teleport back
    root.CFrame = initialCFrame
    print("✅ Teleported back")
end

