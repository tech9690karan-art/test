-- Auto Check-in Toggle
local autoCheckInEnabled = false
local checkInLoop = nil
local AUTO_CHECKIN_POS = CFrame.new(-104.62301635742188, 3.4125311374664307, 6.181607246398926)

Tabs.Main:Toggle({
    Title = "Auto Check In",
    Value = false,
    Callback = function(state)
        autoCheckInEnabled = state
        
        if state then
            WindUI:Notify({
                Title = "Auto Check In",
                Content = "Auto Check In Enabled",
                Duration = 3,
                Icon = "check",
            })
            
            checkInLoop = task.spawn(function()
                -- NPC Check-in Script (CheckIn 1 & CheckIn 2)
                local CHECK_POSITION_1 = CFrame.new(-103.87, 3.41, -7.14)
                local RADIUS = 2
                local CHECK_POSITION_2 = CFrame.new(-91.865051, 3.407531, 8.354979)
                local COOLDOWN_TIME = 30
                local Cooldown = {}
                
                -- Find NPC folder
                local NPCS = nil
                for _, child in ipairs(Workspace:GetChildren()) do
                    if child.Name:lower() == "npc" or child.Name:lower() == "npcs" then
                        NPCS = child
                        break
                    end
                end
                
                if not NPCS then
                    return
                end
                
                -- Find CheckIn 1 folder
                local Misc = Workspace:FindFirstChild("Misc")
                if not Misc then
                    return
                end
                
                local CheckIn = Misc:FindFirstChild("CheckIn")
                if not CheckIn then
                    return
                end
                
                -- Find CheckIn 2 folder
                local CheckIn2 = Misc:FindFirstChild("CheckIn2")
                
                -- Define step order for CheckIn 1
                local checkIn1Steps = {
                    {Name = "Form", Parent = CheckIn},
                    {Name = "Camera", Parent = CheckIn},
                    {Name = "Computer", Parent = CheckIn},
                    {Name = "Printer", Parent = CheckIn},
                    {Name = "PrintedBadge", Parent = CheckIn},
                    {Name = "NPC", Parent = nil},
                }
                
                -- Define step order for CheckIn 2 (will be set once CheckIn2 exists)
                local checkIn2Steps = nil
                
                -- Function to check if NPC is in radius for CheckIn 1
                local function GetNPCInRadius1()
                    for _, npc in ipairs(NPCS:GetChildren()) do
                        if npc:IsA("Model") then
                            local root = npc:FindFirstChild("HumanoidRootPart") or npc.PrimaryPart
                            if root then
                                local dist = (root.Position - CHECK_POSITION_1.Position).Magnitude
                                if dist <= RADIUS then
                                    return npc
                                end
                            end
                        end
                    end
                    return nil
                end
                
                -- Function to check if NPC is in radius for CheckIn 2
                local function GetNPCInRadius2()
                    for _, npc in ipairs(NPCS:GetChildren()) do
                        if npc:IsA("Model") then
                            local root = npc:FindFirstChild("HumanoidRootPart") or npc.PrimaryPart
                            if root then
                                local dist = (root.Position - CHECK_POSITION_2.Position).Magnitude
                                if dist <= RADIUS then
                                    return npc
                                end
                            end
                        end
                    end
                    return nil
                end

                local function UpdateCurrentPatients()
                    local npc1 = GetNPCInRadius1()
                    local npc2 = GetNPCInRadius2()
                
                    local desk1Name = "Waiting..."
                    local desk1Status = "🟡 Empty"
                
                    local desk2Name = "Waiting..."
                    local desk2Status = "🟡 Empty"
                
                    if npc1 then
                        desk1Name = npc1.Name
                        if npc1:GetAttribute("Skinwalker") then
                            desk1Status = "🔴 Anomaly"
                        else
                            desk1Status = "🟢 Patient"
                        end
                    end
                
                    if npc2 then
                        desk2Name = npc2.Name
                        if npc2:GetAttribute("Skinwalker") then
                            desk2Status = "🔴 Anomaly"
                        else
                            desk2Status = "🟢 Patient"
                        end
                    end
                
                    CurrentPatients:SetDesc(string.format([[
                    DESK 1
                    NAME: %s
                    STATUS: %s
                    ____________________
                                    
                    DESK 2
                    NAME: %s
                    STATUS: %s
                    ]], desk1Name, desk1Status, desk2Name, desk2Status))
                end
                        
                local SKIP_NPCS = {
                    Doctor = true,
                    Barney = true,
                }
                
                -- Function to find and fire next highlighted step for an NPC
                -- Returns the step name if fired, nil if nothing found
                local function ProcessNextHighlightedStep(npc, steps)
                    for _, step in ipairs(steps) do
                        local obj
                        if step.Name == "NPC" then
                            obj = npc
                        else
                            local parent = step.Parent
                            if parent then
                                obj = parent:FindFirstChild(step.Name)
                            end
                        end
                        
                        if obj and obj:FindFirstChild("CheckStepHighlight") then
                            local pp = obj:FindFirstChild("PP")
                            if pp then
                                fireproximityprompt(pp)
                                return step.Name
                            end
                        end
                    end
                    return nil
                end
                
                -- Function to process CheckIn 1
                local function ProcessCheckIn1(npc)
                    local isSkinwalker = npc:GetAttribute("Skinwalker")
                    
                    if isSkinwalker then
                        WindUI:Notify({
                            Title = "⚠️ Anomaly Detected!",
                            Content = "Anomaly detected, please close the shutter!",
                            Duration = 5,
                            Icon = "alert-triangle",
                        })
                    end
                    
                    if not SKIP_NPCS[npc.Name] and not isSkinwalker then
                        -- Keep processing while NPC is in radius
                        while autoCheckInEnabled and GetNPCInRadius1() == npc do
                            local stepName = ProcessNextHighlightedStep(npc, checkIn1Steps)
                            
                            if stepName == "NPC" then
                                Cooldown[npc] = tick()
                                return
                            end
                            
                            task.wait(0.05)
                        end
                    end
                end
                
                -- Function to process CheckIn 2
                local function ProcessCheckIn2(npc)
                    local isSkinwalker = npc:GetAttribute("Skinwalker")
                    
                    if isSkinwalker then
                        WindUI:Notify({
                            Title = "⚠️ Anomaly Detected!",
                            Content = "Anomaly detected, please close the shutter!",
                            Duration = 5,
                            Icon = "alert-triangle",
                        })
                    end
                    
                    if not SKIP_NPCS[npc.Name] and not isSkinwalker and checkIn2Steps then
                        -- Keep processing while NPC is in radius
                        while autoCheckInEnabled and GetNPCInRadius2() == npc do
                            local stepName = ProcessNextHighlightedStep(npc, checkIn2Steps)
                            
                            if stepName == "NPC" then
                                Cooldown[npc] = tick()
                                return
                            end
                            
                            task.wait(0.05)
                        end
                    end
                end

                -- Player positioning thread
                task.spawn(function()
                    while autoCheckInEnabled do
                        local character = LocalPlayer.Character
                        if character then
                            local root = character:FindFirstChild("HumanoidRootPart")
                            if root then
                                root.CFrame = AUTO_CHECKIN_POS
                            end
                        end
                        task.wait(0.1)
                    end
                end)
                        
                -- Main loop
                while autoCheckInEnabled do
                    UpdateCurrentPatients()
                            
                    -- Clean up cooldowns older than 30 seconds
                    for npc, t in pairs(Cooldown) do
                        if tick() - t >= COOLDOWN_TIME then
                            Cooldown[npc] = nil
                        end
                    end
                    
                    -- Check for NPC in CheckIn 1 radius
                    local npc1 = GetNPCInRadius1()
                    if npc1 and not Cooldown[npc1] then
                        ProcessCheckIn1(npc1)
                    end
                    
                    -- Check for CheckIn 2 folder and set up steps once
                    if not CheckIn2 then
                        CheckIn2 = Misc:FindFirstChild("CheckIn2")
                        if CheckIn2 and not checkIn2Steps then
                            checkIn2Steps = {
                                {Name = "Form", Parent = CheckIn2},
                                {Name = "Camera", Parent = CheckIn2},
                                {Name = "Computer", Parent = CheckIn},
                                {Name = "Printer", Parent = CheckIn},
                                {Name = "PrintedBadge", Parent = CheckIn},
                                {Name = "NPC", Parent = nil},
                            }
                        end
                    end
                    
                    if CheckIn2 and checkIn2Steps then
                        local npc2 = GetNPCInRadius2()
                        if npc2 and not Cooldown[npc2] then
                            ProcessCheckIn2(npc2)
                        end
                    end
                    
                    task.wait(0.5)
                end
            end)
        else
            if checkInLoop then
                autoCheckInEnabled = false

                CurrentPatients:SetDesc([[
                DESK 1
                NAME: Waiting...
                STATUS: 🟡 Empty
                ____________________
                        
                DESK 2
                NAME: Waiting...
                STATUS: 🟡 Empty
                ]])
                    
                checkInLoop = nil
            end
            WindUI:Notify({
                Title = "Auto Check In",
                Content = "Auto Check In Disabled",
                Duration = 3,
                Icon = "x",
            })
        end
    end
})

