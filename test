-- NPC Check-in Script Functions
local function SetupCheckInSystem()
    -- Find NPC folder
    local NPCS = nil
    for _, child in ipairs(Workspace:GetChildren()) do
        if child.Name:lower() == "npc" or child.Name:lower() == "npcs" then
            NPCS = child
            break
        end
    end
    
    if not NPCS then
        WindUI:Notify({
            Title = "❌ Error",
            Content = "NPC folder not found",
            Duration = 3,
            Icon = "alert-circle",
        })
        return nil
    end
    
    -- Find Misc folder
    local Misc = Workspace:FindFirstChild("Misc")
    if not Misc then
        WindUI:Notify({
            Title = "❌ Error",
            Content = "Misc folder not found",
            Duration = 3,
            Icon = "alert-circle",
        })
        return nil
    end
    
    local CheckIn = Misc:FindFirstChild("CheckIn")
    if not CheckIn then
        WindUI:Notify({
            Title = "❌ Error",
            Content = "CheckIn folder not found",
            Duration = 3,
            Icon = "alert-circle",
        })
        return nil
    end
    
    return {
        NPCS = NPCS,
        Misc = Misc,
        CheckIn = CheckIn,
        CheckIn2 = Misc:FindFirstChild("CheckIn2")
    }
end

local function GetNPCInRadius(checkPosition, radius, npcs)
    for _, npc in ipairs(npcs:GetChildren()) do
        if npc:IsA("Model") then
            local root = npc:FindFirstChild("HumanoidRootPart") or npc.PrimaryPart
            if root then
                local dist = (root.Position - checkPosition.Position).Magnitude
                if dist <= radius then
                    return npc
                end
            end
        end
    end
    return nil
end

local function FirePrompt(prompt)
    if prompt then
        fireproximityprompt(prompt)
    end
end

local function ProcessCheckIn(npc, checkInFolder, prompts, isCheckIn2)
    local SKIP_NPCS = {
        Doctor = true,
        Barney = true,
    }
    
    -- Check if Skinwalker
    local isSkinwalker = npc:GetAttribute("Skinwalker")
    
    if SKIP_NPCS[npc.Name] then
        return
    end
    
    if isSkinwalker then
        WindUI:Notify({
            Title = "⚠️ Anomalie Detected!",
            Content = "Please close the shutter!",
            Duration = 5,
            Icon = "alert-triangle",
        })
        return
    end
    
    -- Process the check-in steps
    local steps = isCheckIn2 and {"Form", "Camera"} or {"Form", "Camera", "Computer", "Printer", "PrintedBadge"}
    
    for _, stepName in ipairs(steps) do
        local stepObj = checkInFolder:FindFirstChild(stepName)
        if stepObj then
            local highlight = stepObj:FindFirstChild("CheckStepHighlight")
            if highlight then
                local pp = stepObj:FindFirstChild("PP")
                if pp then
                    FirePrompt(pp)
                    task.wait(0.5)
                end
            end
        end
    end
    
    -- Fire NPC prompt
    if npc:FindFirstChild("CheckStepHighlight") then
        local npcPrompt = npc:FindFirstChild("PP")
        if npcPrompt then
            FirePrompt(npcPrompt)
        end
    end
end

-- Auto Check-in Toggle
Tabs.Main:Toggle({
    Title = "Auto Check-in",
    Value = false,
    Callback = function(state)
        autoCheckInEnabled = state
        
        if state then
            checkInLoopRunning = true
            
            WindUI:Notify({
                Title = "✅ Auto Check-in Enabled",
                Content = "Starting check-in loop...",
                Duration = 2,
                Icon = "play",
            })
            
            task.spawn(function()
                local system = SetupCheckInSystem()
                if not system then
                    checkInLoopRunning = false
                    autoCheckInEnabled = false
                    return
                end
                
                local CHECK_POSITION_1 = CFrame.new(-103.87, 3.41, -7.14)
                local CHECK_POSITION_2 = CFrame.new(-91.865051, 3.407531, 8.354979)
                local RADIUS = 2
                local COOLDOWN_TIME = 30
                local Cooldown = {}
                
                -- Get prompts for CheckIn 1
                local prompts1 = {
                    Form = system.CheckIn:FindFirstChild("Form") and system.CheckIn.Form:FindFirstChild("PP"),
                    Camera = system.CheckIn:FindFirstChild("Camera") and system.CheckIn.Camera:FindFirstChild("PP"),
                    Computer = system.CheckIn:FindFirstChild("Computer") and system.CheckIn.Computer:FindFirstChild("PP"),
                    Printer = system.CheckIn:FindFirstChild("Printer") and system.CheckIn.Printer:FindFirstChild("PP"),
                    PrintedBadge = system.CheckIn:FindFirstChild("PrintedBadge") and system.CheckIn.PrintedBadge:FindFirstChild("PP"),
                }
                
                -- Check if all prompts exist
                for name, prompt in pairs(prompts1) do
                    if not prompt then
                        WindUI:Notify({
                            Title = "❌ Error",
                            Content = "Missing prompt in CheckIn 1: " .. name,
                            Duration = 3,
                            Icon = "alert-circle",
                        })
                        checkInLoopRunning = false
                        autoCheckInEnabled = false
                        return
                    end
                end
                
                while checkInLoopRunning and autoCheckInEnabled do
                    -- Clean cooldowns
                    for npc, t in pairs(Cooldown) do
                        if tick() - t >= COOLDOWN_TIME then
                            Cooldown[npc] = nil
                        end
                    end
                    
                    -- Check CheckIn 1
                    local npc1 = GetNPCInRadius(CHECK_POSITION_1, RADIUS, system.NPCS)
                    if npc1 and not Cooldown[npc1] then
                        ProcessCheckIn(npc1, system.CheckIn, prompts1, false)
                        Cooldown[npc1] = tick()
                    end
                    
                    -- Check CheckIn 2
                    if system.CheckIn2 then
                        local prompts2 = {
                            Form = system.CheckIn2:FindFirstChild("Form") and system.CheckIn2.Form:FindFirstChild("PP"),
                            Camera = system.CheckIn2:FindFirstChild("Camera") and system.CheckIn2.Camera:FindFirstChild("PP"),
                        }
                        
                        local npc2 = GetNPCInRadius(CHECK_POSITION_2, RADIUS, system.NPCS)
                        if npc2 and not Cooldown[npc2] then
                            ProcessCheckIn(npc2, system.CheckIn2, prompts2, true)
                            Cooldown[npc2] = tick()
                        end
                    end
                    
                    task.wait(0.5)
                end
            end)
        else
            checkInLoopRunning = false
            WindUI:Notify({
                Title = "⏹️ Auto Check-in Disabled",
                Content = "Stopped check-in loop",
                Duration = 2,
                Icon = "stop",
            })
        end
    end
})

