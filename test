print("🚀 Script started (CheckIn 1 & CheckIn 2)")

-- Main loop
while true do
    -- Clean up cooldowns older than 30 seconds
    for npc, t in pairs(Cooldown) do
        if tick() - t >= COOLDOWN_TIME then
            Cooldown[npc] = nil
            print("🧹 Removed cooldown for:", npc.Name)
        end
    end
    
    -- Check for NPC in CheckIn 1 radius
    local npc1 = GetNPCInRadius1()
    if npc1 then
        if Cooldown[npc1] then
            print("⏭️ NPC on cooldown:", npc1.Name)
        else
            ProcessCheckIn1(npc1)
        end
    end
    
    -- Check for CheckIn 2 folder and NPC in CheckIn 2 radius
    if not CheckIn2 then
        CheckIn2 = Misc:FindFirstChild("CheckIn2")
        if CheckIn2 then
            print("✅ CheckIn2 folder found")
            prompts2 = {
                Form = CheckIn2:FindFirstChild("Form") and CheckIn2.Form:FindFirstChild("PP"),
                Camera = CheckIn2:FindFirstChild("Camera") and CheckIn2.Camera:FindFirstChild("PP"),
            }
        end
    end
    
    if CheckIn2 then
        local npc2 = GetNPCInRadius2()
        if npc2 then
            if Cooldown[npc2] then
                print("⏭️ NPC on cooldown:", npc2.Name)
            else
                ProcessCheckIn2(npc2)
            end
        end
    end
    
    task.wait(0.5)
end
