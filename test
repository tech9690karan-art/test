-- ESP Functions
local function SetupESP()
    local NPCS = nil
    for _, child in ipairs(Workspace:GetChildren()) do
        if child.Name:lower() == "npc" or child.Name:lower() == "npcs" then
            NPCS = child
            break
        end
    end
    
    if not NPCS then
        WindUI:Notify({
            Title = "❌ Error",
            Content = "NPC folder not found",
            Duration = 3,
            Icon = "alert-circle",
        })
        return nil
    end
    
    return NPCS
end

local function CreateHighlight(npc, isAnomaly)
    local highlight = Instance.new("Highlight")
    highlight.Name = "ESP_Highlight"
    highlight.FillTransparency = 0.5
    highlight.OutlineColor = Color3.new(1, 1, 1)
    highlight.OutlineTransparency = 0
    highlight.Parent = npc
    
    if isAnomaly then
        highlight.FillColor = Color3.new(1, 0, 0) -- Red for anomalies
    else
        highlight.FillColor = Color3.new(0, 1, 0) -- Green for patients
    end
    
    return highlight
end

local function RemoveHighlight(npc)
    if espHighlights[npc] then
        espHighlights[npc]:Destroy()
        espHighlights[npc] = nil
    end
end

local function UpdateESP(npc, isAnomaly, enabled)
    if not enabled then
        RemoveHighlight(npc)
        return
    end
    
    if not espHighlights[npc] then
        espHighlights[npc] = CreateHighlight(npc, isAnomaly)
    else
        -- Update color based on type
        if isAnomaly then
            espHighlights[npc].FillColor = Color3.new(1, 0, 0)
        else
            espHighlights[npc].FillColor = Color3.new(0, 1, 0)
        end
        espHighlights[npc].Enabled = true
    end
end

-- ESP Anomalies Toggle
Tabs.ESP:Toggle({
    Title = "ESP Anomalies",
    Desc = "Shows anomalies with red highlight",
    Value = false,
    Callback = function(state)
        espAnomaliesEnabled = state
        
        if state then
            WindUI:Notify({
                Title = "👁️ ESP Anomalies Enabled",
                Content = "Highlighting anomalies...",
                Duration = 2,
                Icon = "eye",
            })
        else
            WindUI:Notify({
                Title = "👁️ ESP Anomalies Disabled",
                Content = "Removed anomaly highlights",
                Duration = 2,
                Icon = "eye-off",
            })
        end
        
        -- Start ESP loop if either is enabled
        if espAnomaliesEnabled or espPatientsEnabled then
            if not espRunning then
                espRunning = true
                task.spawn(function()
                    local NPCS = SetupESP()
                    if not NPCS then
                        espRunning = false
                        return
                    end
                    
                    while espRunning and (espAnomaliesEnabled or espPatientsEnabled) do
                        local currentNPCs = {}
                        
                        for _, npc in ipairs(NPCS:GetChildren()) do
                            if npc:IsA("Model") and npc ~= LocalPlayer.Character then
                                local root = npc:FindFirstChild("HumanoidRootPart") or 
                                            npc:FindFirstChild("Head") or 
                                            npc.PrimaryPart
                                if root then
                                    local distance = (root.Position - Workspace.CurrentCamera.CFrame.Position).Magnitude
                                    if distance <= 1000 then
                                        currentNPCs[npc] = true
                                        
                                        local isSkinwalker = npc:GetAttribute("Skinwalker")
                                        
                                        -- Check if this NPC should be shown
                                        if isSkinwalker and espAnomaliesEnabled then
                                            UpdateESP(npc, true, true)
                                        elseif not isSkinwalker and espPatientsEnabled then
                                            UpdateESP(npc, false, true)
                                        else
                                            RemoveHighlight(npc)
                                        end
                                    end
                                end
                            end
                        end
                        
                        -- Remove ESP for NPCs no longer in range or not matching filters
                        for npc, highlight in pairs(espHighlights) do
                            if not currentNPCs[npc] then
                                RemoveHighlight(npc)
                            end
                        end
                        
                        task.wait(0.5)
                    end
                    
                    -- Clean up all highlights when loop ends
                    for npc, highlight in pairs(espHighlights) do
                        RemoveHighlight(npc)
                    end
                    espRunning = false
                end)
            end
        else
            -- Disable ESP
            espRunning = false
            for npc, highlight in pairs(espHighlights) do
                RemoveHighlight(npc)
            end
        end
    end
})

