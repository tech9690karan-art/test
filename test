-- Main check-in loop
task.spawn(function()
    while true do
        if isScriptEnabled then
            pcall(function()
                local character = LocalPlayer.Character
                if character then
                    local humanoidRootPart = character:FindFirstChild("HumanoidRootPart")
                    if humanoidRootPart then
                        humanoidRootPart.CFrame = ANCHOR_POSITION
                    end
                end
            end)
            
            for npc, t in pairs(Cooldown) do
                if tick() - t >= COOLDOWN_TIME then
                    Cooldown[npc] = nil
                end
            end
            
            local npc1 = GetNPCInRadius1()
            if npc1 then
                if Cooldown[npc1] then
                else
                    ProcessCheckIn1(npc1)
                end
            end
            
            if not CheckIn2 then
                CheckIn2 = Misc:FindFirstChild("CheckIn2")
                if CheckIn2 then
                    prompts2 = {
                        Form = CheckIn2:FindFirstChild("Form") and CheckIn2.Form:FindFirstChild("PP"),
                        Camera = CheckIn2:FindFirstChild("Camera") and CheckIn2.Camera:FindFirstChild("PP"),
                    }
                end
            end
            
            if CheckIn2 then
                local npc2 = GetNPCInRadius2()
                if npc2 then
                    if Cooldown[npc2] then
                    else
                        ProcessCheckIn2(npc2)
                    end
                end
            end
        end
        
        task.wait(0.5)
    end
end)

