-- CheckIn Config
local CHECK_POSITION_1 = CFrame.new(-103.87, 3.41, -7.14)
local CHECK_POSITION_2 = CFrame.new(-91.865051, 3.407531, 8.354979)
local ANCHOR_POSITION = CFrame.new(-104.62301635742188, 3.4125311374664307, 6.181607246398926)
local RADIUS = 2
local COOLDOWN_TIME = 30
local Cooldown = {}
local isScriptEnabled = false

-- Check-in variables (initialized when toggle is turned on)
local NPCS = nil
local Misc = nil
local CheckIn = nil
local CheckIn2 = nil
local prompts = nil
local prompts2 = nil

-- Function to initialize check-in components
local function InitializeCheckIn()
    -- Find NPC folder
    NPCS = nil
    for _, child in ipairs(Workspace:GetChildren()) do
        if child.Name:lower() == "npc" or child.Name:lower() == "npcs" then
            NPCS = child
            break
        end
    end
    
    if not NPCS then
        return false, "NPC folder not found"
    end
    
    -- Find CheckIn folders
    Misc = Workspace:FindFirstChild("Misc")
    if not Misc then
        return false, "Misc folder not found"
    end
    
    CheckIn = Misc:FindFirstChild("CheckIn")
    if not CheckIn then
        return false, "CheckIn folder not found"
    end
    
    CheckIn2 = Misc:FindFirstChild("CheckIn2")
    
    -- Get all ProximityPrompts for CheckIn 1
    prompts = {
        Form = CheckIn:FindFirstChild("Form") and CheckIn.Form:FindFirstChild("PP"),
        Camera = CheckIn:FindFirstChild("Camera") and CheckIn.Camera:FindFirstChild("PP"),
        Computer = CheckIn:FindFirstChild("Computer") and CheckIn.Computer:FindFirstChild("PP"),
        Printer = CheckIn:FindFirstChild("Printer") and CheckIn.Printer:FindFirstChild("PP"),
        PrintedBadge = CheckIn:FindFirstChild("PrintedBadge") and CheckIn.PrintedBadge:FindFirstChild("PP"),
    }
    
    -- Validate CheckIn 1 prompts
    for name, prompt in pairs(prompts) do
        if not prompt then
            return false, "Missing prompt in CheckIn 1: " .. name
        end
    end
    
    -- Get prompts for CheckIn 2 if it exists
    if CheckIn2 then
        prompts2 = {
            Form = CheckIn2:FindFirstChild("Form") and CheckIn2.Form:FindFirstChild("PP"),
            Camera = CheckIn2:FindFirstChild("Camera") and CheckIn2.Camera:FindFirstChild("PP"),
        }
        
        for name, prompt in pairs(prompts2) do
            if not prompt then
                return false, "Missing prompt in CheckIn 2: " .. name
            end
        end
    end
    
    return true, "Ready"
end

-- Function to fire a prompt
local function FirePrompt(prompt)
    if prompt then
        fireproximityprompt(prompt)
    end
end

-- Function to check if NPC is in radius for CheckIn 1
local function GetNPCInRadius1()
    if not NPCS then return nil end
    for _, npc in ipairs(NPCS:GetChildren()) do
        if npc:IsA("Model") then
            local root = npc:FindFirstChild("HumanoidRootPart") or npc.PrimaryPart
            if root then
                local dist = (root.Position - CHECK_POSITION_1.Position).Magnitude
                if dist <= RADIUS then
                    return npc
                end
            end
        end
    end
    return nil
end

-- Function to check if NPC is in radius for CheckIn 2
local function GetNPCInRadius2()
    if not NPCS then return nil end
    for _, npc in ipairs(NPCS:GetChildren()) do
        if npc:IsA("Model") then
            local root = npc:FindFirstChild("HumanoidRootPart") or npc.PrimaryPart
            if root then
                local dist = (root.Position - CHECK_POSITION_2.Position).Magnitude
                if dist <= RADIUS then
                    return npc
                end
            end
        end
    end
    return nil
end

local SKIP_NPCS = {
    Doctor = true,
    Barney = true,
}

-- Function to process CheckIn 1
local function ProcessCheckIn1(npc)
    if not CheckIn then return end
    
    local isSkinwalker = npc:GetAttribute("Skinwalker")
    
    if isSkinwalker then
        WindUI:Notify({
            Title = "⚠️ Anomaly Detected!",
            Content = "Anomaly detected, please close the shutter!",
            Duration = 5,
            Icon = "alert-triangle",
        })
    end
    
    if SKIP_NPCS[npc.Name] then
    elseif not isSkinwalker then
        local Form = CheckIn:WaitForChild("Form")
        Form:WaitForChild("CheckStepHighlight")
        FirePrompt(Form:WaitForChild("PP"))
        task.wait(0.5)
        
        CheckIn.Camera:WaitForChild("CheckStepHighlight")
        FirePrompt(prompts.Camera)
        task.wait(0.5)
        
        CheckIn.Computer:WaitForChild("CheckStepHighlight")
        FirePrompt(prompts.Computer)
        task.wait(0.5)
        
        CheckIn.Printer:WaitForChild("CheckStepHighlight")
        FirePrompt(prompts.Printer)
        task.wait(0.5)
        
        local PrintedBadge = CheckIn:WaitForChild("PrintedBadge")
        PrintedBadge:WaitForChild("CheckStepHighlight")
        FirePrompt(PrintedBadge:WaitForChild("PP"))
        task.wait(0.5)
        
        if npc:FindFirstChild("CheckStepHighlight") then
            local npcPrompt = npc:FindFirstChild("PP")
            if npcPrompt then
                fireproximityprompt(npcPrompt)
            end
        end
        
        Cooldown[npc] = tick()
    end
end

