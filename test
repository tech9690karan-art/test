-- Check if Carrot is actually a Tool or a Part
local carrot = Workspace.Items:FindFirstChild("Carrot")
if carrot then
    print("Carrot details:")
    print("  ClassName:", carrot.ClassName)
    print("  IsA Tool:", carrot:IsA("Tool"))
    print("  IsA BasePart:", carrot:IsA("BasePart"))
    print("  IsA Model:", carrot:IsA("Model"))
    
    -- Check if it has a Handle
    local handle = carrot:FindFirstChild("Handle")
    print("  Has Handle:", handle ~= nil)
    
    -- Check for ProximityPrompt
    local prompt = carrot:FindFirstChildOfClass("ProximityPrompt")
    print("  Has ProximityPrompt:", prompt ~= nil)
    if prompt then
        print("  Prompt ActionText:", prompt.ActionText)
        print("  Prompt KeyboardKeyCode:", prompt.KeyboardKeyCode)
    end
end
