local function DeepDebug()
    local Players = game:GetService("Players")
    local LocalPlayer = Players.LocalPlayer
    
    if not LocalPlayer then
        print("❌ LocalPlayer not found")
        return
    end
    
    local gui = LocalPlayer:FindFirstChild("PlayerGui")
    
    if not gui then
        print("❌ No PlayerGui found")
        return
    end
    
    local shakeui = gui:FindFirstChild("shakeui")
    
    if not shakeui then
        print("❌ No shakeui found - waiting for fish bite...")
        return
    end
    
    print("=== SHAKE UI DEBUG ===")
    print("shakeui Visible:", shakeui.Visible)
    print("")
    
    -- Print ALL children of shakeui
    print("--- shakeui Children ---")
    for _, child in pairs(shakeui:GetChildren()) do
        print("•", child.Name, "-", child.ClassName, "- Visible:", pcall(function() return child.Visible end))
    end
    
    -- Check safezone
    local safezone = shakeui:FindFirstChild("safezone")
    if safezone then
        print("\n--- safezone Children ---")
        for _, child in pairs(safezone:GetChildren()) do
            print("•", child.Name, "-", child.ClassName, "- Visible:", pcall(function() return child.Visible end))
        end
        
        -- Check button
        local button = safezone:FindFirstChild("button")
        if button then
            print("\n--- button Details ---")
            print("ClassName:", button.ClassName)
            pcall(function() print("Visible:", button.Visible) end)
            pcall(function() print("Active:", button.Active) end)
            
            print("\n--- button Children ---")
            for _, child in pairs(button:GetChildren()) do
                print("•", child.Name, "-", child.ClassName)
            end
        else
            print("\n❌ No button found in safezone")
        end
    else
        print("\n❌ No safezone found")
    end
    
    -- Search ALL RemoteEvents in the entire game
    print("\n--- Searching All Shake RemoteEvents ---")
    local rs = game:GetService("ReplicatedStorage")
    local found = false
    
    -- Search in ReplicatedStorage
    for _, child in pairs(rs:GetDescendants()) do
        if child:IsA("RemoteEvent") and child.Name:lower():find("shake") then
            print("🔍 FOUND:", child:GetFullName())
            found = true
        end
    end
    
    -- Search in PlayerGui
    for _, child in pairs(gui:GetDescendants()) do
        if child:IsA("RemoteEvent") and child.Name:lower():find("shake") then
            print("🔍 FOUND in GUI:", child:GetFullName())
            found = true
        end
    end
    
    if not found then
        print("❌ No shake RemoteEvents found anywhere!")
    end
    
    -- Try to find any RemoteFunction related to shake
    print("\n--- Searching Shake RemoteFunctions ---")
    local foundFunc = false
    for _, child in pairs(rs:GetDescendants()) do
        if child:IsA("RemoteFunction") and child.Name:lower():find("shake") then
            print("🔍 FOUND RemoteFunction:", child:GetFullName())
            foundFunc = true
        end
    end
    
    if not foundFunc then
        print("No shake RemoteFunctions found")
    end
    
    -- Also search for BindableEvents
    print("\n--- Searching BindableEvents ---")
    for _, child in pairs(rs:GetDescendants()) do
        if child:IsA("BindableEvent") and child.Name:lower():find("shake") then
            print("🔍 FOUND BindableEvent:", child:GetFullName())
        end
    end
end

-- Run this when fish bites
DeepDebug()
