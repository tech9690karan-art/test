        local initialCFrame = root.CFrame
        
        -- Teleport to coffee machine
        root.CFrame = CFrame.new(-120.53153991699219, 3.4125311374664307, 9.277679443359375)
        task.wait(0.5)
        
        -- Fire prompt
        local success, result = pcall(function()
            local CoffeeMachine = Workspace:WaitForChild("Misc"):WaitForChild("CoffeeMachine")
            local Coffee = CoffeeMachine:WaitForChild("Coffee")
            return Coffee:WaitForChild("PP")
        end)
        
        if success and result then
