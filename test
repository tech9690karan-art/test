-- NPC Check-in Script (CheckIn 1 & CheckIn 2)
local Workspace = game:GetService("Workspace")

-- CheckIn 1 Config
local CHECK_POSITION_1 = CFrame.new(-103.87, 3.41, -7.14)
local RADIUS = 2

-- CheckIn 2 Config
local CHECK_POSITION_2 = CFrame.new(-91.865051, 3.407531, 8.354979)

local COOLDOWN_TIME = 30
local Cooldown = {}

-- Find NPC folder
local NPCS = nil
for _, child in ipairs(Workspace:GetChildren()) do
    if child.Name:lower() == "npc" or child.Name:lower() == "npcs" then
        NPCS = child
        break
    end
end

if not NPCS then
    print("❌ NPC folder not found")
    return
end

print("✅ NPC folder found:", NPCS.Name)

-- Find CheckIn 1 folder
local Misc = Workspace:FindFirstChild("Misc")
if not Misc then
    print("❌ Misc folder not found")
    return
end

local CheckIn = Misc:FindFirstChild("CheckIn")
if not CheckIn then
    print("❌ CheckIn folder not found")
    return
end

print("✅ CheckIn folder found")

-- Find CheckIn 2 folder
local CheckIn2 = Misc:FindFirstChild("CheckIn2")
if not CheckIn2 then
    print("⚠️ CheckIn2 folder not found, will keep checking...")
end

-- Get all ProximityPrompts for CheckIn 1
local prompts = {
    Form = CheckIn:FindFirstChild("Form") and CheckIn.Form:FindFirstChild("PP"),
    Camera = CheckIn:FindFirstChild("Camera") and CheckIn.Camera:FindFirstChild("PP"),
    Computer = CheckIn:FindFirstChild("Computer") and CheckIn.Computer:FindFirstChild("PP"),
    Printer = CheckIn:FindFirstChild("Printer") and CheckIn.Printer:FindFirstChild("PP"),
    PrintedBadge = CheckIn:FindFirstChild("PrintedBadge") and CheckIn.PrintedBadge:FindFirstChild("PP"),
}

-- Get all ProximityPrompts for CheckIn 2
local prompts2 = nil
if CheckIn2 then
    prompts2 = {
        Form = CheckIn2:FindFirstChild("Form") and CheckIn2.Form:FindFirstChild("PP"),
        Camera = CheckIn2:FindFirstChild("Camera") and CheckIn2.Camera:FindFirstChild("PP"),
    }
end

-- Check if all prompts exist for CheckIn 1
for name, prompt in pairs(prompts) do
    if not prompt then
        print("❌ Missing prompt in CheckIn 1:", name)
        return
    end
end

print("✅ All CheckIn 1 prompts found")

-- Check if all prompts exist for CheckIn 2
if CheckIn2 then
    for name, prompt in pairs(prompts2) do
        if not prompt then
            print("❌ Missing prompt in CheckIn 2:", name)
            return
        end
    end
    print("✅ All CheckIn 2 prompts found")
end

-- Function to fire a prompt
local function FirePrompt(prompt)
    if prompt then
        print("🔥 Firing prompt:", prompt.Parent.Name)
        fireproximityprompt(prompt)
    end
end

-- Function to check if NPC is in radius for CheckIn 1
local function GetNPCInRadius1()
    for _, npc in ipairs(NPCS:GetChildren()) do
        if npc:IsA("Model") then
            local root = npc:FindFirstChild("HumanoidRootPart") or npc.PrimaryPart
            if root then
                local dist = (root.Position - CHECK_POSITION_1.Position).Magnitude
                if dist <= RADIUS then
                    print("✅ NPC in CheckIn 1 radius:", npc.Name)
                    return npc
                end
            end
        end
    end
    return nil
end

-- Function to check if NPC is in radius for CheckIn 2
local function GetNPCInRadius2()
    for _, npc in ipairs(NPCS:GetChildren()) do
        if npc:IsA("Model") then
            local root = npc:FindFirstChild("HumanoidRootPart") or npc.PrimaryPart
            if root then
                local dist = (root.Position - CHECK_POSITION_2.Position).Magnitude
                if dist <= RADIUS then
                    print("✅ NPC in CheckIn 2 radius:", npc.Name)
                    return npc
                end
            end
        end
    end
    return nil
end

local SKIP_NPCS = {
    Doctor = true,
    Barney = true,
}

-- Function to process CheckIn 1
local function ProcessCheckIn1(npc)
    print("🔍 Processing NPC in CheckIn 1:", npc.Name)
    
    -- Check if Skinwalker attribute is enabled
    local isSkinwalker = npc:GetAttribute("Skinwalker")
    
    if SKIP_NPCS[npc.Name] then
        print("⏭️ Permanently skipping:", npc.Name)
    elseif not isSkinwalker then
        -- Wait for Form to exist before checking it
        local Form = CheckIn:WaitForChild("Form")
        
        print("⏳ Waiting for Form CheckStepHighlight...")
        Form:WaitForChild("CheckStepHighlight")
        print("✅ Form CheckStepHighlight found")
        FirePrompt(Form:WaitForChild("PP"))
        task.wait(0.5)
        
        print("⏳ Waiting for Camera CheckStepHighlight...")
        CheckIn.Camera:WaitForChild("CheckStepHighlight")
        print("✅ Camera CheckStepHighlight found")
        FirePrompt(prompts.Camera)
        task.wait(0.5)
        
        print("⏳ Waiting for Computer CheckStepHighlight...")
        CheckIn.Computer:WaitForChild("CheckStepHighlight")
        print("✅ Computer CheckStepHighlight found")
        FirePrompt(prompts.Computer)
        task.wait(0.5)
        
        print("⏳ Waiting for Printer CheckStepHighlight...")
        CheckIn.Printer:WaitForChild("CheckStepHighlight")
        print("✅ Printer CheckStepHighlight found")
        FirePrompt(prompts.Printer)
        task.wait(0.5)
        
        -- Wait for PrintedBadge to exist before checking it
        local PrintedBadge = CheckIn:WaitForChild("PrintedBadge")
        
        print("⏳ Waiting for PrintedBadge CheckStepHighlight...")
        PrintedBadge:WaitForChild("CheckStepHighlight")
        print("✅ PrintedBadge CheckStepHighlight found")
        FirePrompt(PrintedBadge:WaitForChild("PP"))
        task.wait(0.5)
        
        -- Fire the NPC's own prompt only if CheckStepHighlight exists
        if npc:FindFirstChild("CheckStepHighlight") then
            print("✅ NPC CheckStepHighlight found")
            
            local npcPrompt = npc:FindFirstChild("PP")
            if npcPrompt then
                print("🔥 Firing NPC prompt:", npc.Name)
                fireproximityprompt(npcPrompt)
            else
                print("❌ NPC prompt not found for:", npc.Name)
            end
        else
            print("⏭️ NPC CheckStepHighlight not found for:", npc.Name)
        end
        
        -- Put NPC on cooldown
        Cooldown[npc] = tick()
        print("⏱️ Added cooldown for:", npc.Name)
    else
        print("⏭️ NPC is a Skinwalker, skipping:", npc.Name)
    end
end

