-- ESP Variables
local highlights = {}
local espAnomaliesEnabled = false
local espPatientsEnabled = false
local espConnection = nil

local function CreateHighlight(npc)
    local highlight = Instance.new("Highlight")
    highlight.Name = "ESP_Highlight"
    highlight.FillTransparency = 0.5
    highlight.OutlineColor = Color3.new(1, 1, 1)
    highlight.OutlineTransparency = 0
    highlight.Parent = npc
    
    local isSkinwalker = npc:GetAttribute("Skinwalker")
    if isSkinwalker then
        highlight.FillColor = Color3.new(1, 0, 0) -- Red fill for anomalies
    else
        highlight.FillColor = Color3.new(0, 1, 0) -- Green fill for patients
    end
    
    return highlight
end

local function RemoveHighlight(npc)
    if highlights[npc] then
        highlights[npc]:Destroy()
        highlights[npc] = nil
    end
end

local function UpdateESP()
    local NPCS = nil
    for _, child in ipairs(Workspace:GetChildren()) do
        if child.Name:lower() == "npc" or child.Name:lower() == "npcs" then
            NPCS = child
            break
        end
    end
    
    if not NPCS then return end
    
    local MAX_DISTANCE = 1000
    local Camera = Workspace.CurrentCamera
    
    -- Track current NPCs
    local currentNPCs = {}
    
    for _, npc in ipairs(NPCS:GetChildren()) do
        if npc:IsA("Model") and npc ~= LocalPlayer.Character then
            local root = npc:FindFirstChild("HumanoidRootPart") or npc:FindFirstChild("Head") or npc.PrimaryPart
            if root then
                local distance = (root.Position - Camera.CFrame.Position).Magnitude
                local isSkinwalker = npc:GetAttribute("Skinwalker")
                
                -- Check if we should show this NPC based on toggles
                local shouldShow = false
                if espAnomaliesEnabled and isSkinwalker then
                    shouldShow = true
                end
                if espPatientsEnabled and not isSkinwalker then
                    shouldShow = true
                end
                
                if shouldShow and distance <= MAX_DISTANCE then
                    currentNPCs[npc] = true
                    
                    if not highlights[npc] then
                        highlights[npc] = CreateHighlight(npc)
                    end
                    
                    highlights[npc].Enabled = true
                    if isSkinwalker then
                        highlights[npc].FillColor = Color3.new(1, 0, 0)
                    else
                        highlights[npc].FillColor = Color3.new(0, 1, 0)
                    end
                end
            end
        end
    end
    
    -- Remove ESP for NPCs no longer in range or not matching toggle
    for npc, highlight in pairs(highlights) do
        if not currentNPCs[npc] then
            RemoveHighlight(npc)
        end
    end
end

