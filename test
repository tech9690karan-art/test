            })

            if not walkSpeedConnection then
                walkSpeedConnection = RunService.Heartbeat:Connect(function()
                    ApplyWalkSpeed()
                end)
            end

        else
            WindUI:Notify({
                Title = "WalkSpeed",
                Content = "WalkSpeed Disabled",
                Duration = 3,
                Icon = "x",
            })

            if walkSpeedConnection then
                walkSpeedConnection:Disconnect()
                walkSpeedConnection = nil
            end
                
            ApplyWalkSpeed()
                
        end
    end
})

