-- Helper Functions (add these if not already present)
function wiki(nome)
    local c = 0
    
    -- Check ground items
    if Workspace:FindFirstChild("Items") then
        for _, i in ipairs(Workspace.Items:GetChildren()) do
            if i.Name == nome then
                c = c + 1
            end
        end
    end
    
    -- Check Roblox Backpack
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    if backpack then
        for _, i in ipairs(backpack:GetChildren()) do
            if i.Name == nome then
                c = c + 1
            end
        end
    end
    
    -- Check custom Inventory
    local inventory = LocalPlayer:FindFirstChild("Inventory")
    if inventory then
        for _, i in ipairs(inventory:GetChildren()) do
            if i.Name == nome then
                c = c + 1
            end
        end
    end
    
    return c
end

function ghn()
    local playerGui = LocalPlayer:FindFirstChild("PlayerGui")
    if playerGui then
        local interface = playerGui:FindFirstChild("Interface")
        if interface then
            local statBars = interface:FindFirstChild("StatBars")
            if statBars then
                local hungerBar = statBars:FindFirstChild("HungerBar")
                if hungerBar then
                    local bar = hungerBar:FindFirstChild("Bar")
                    if bar then
                        return math.floor(bar.Size.X.Scale * 100)
                    end
                end
            end
        end
    end
    return 100 -- Default to full if GUI not found
end

function feed(nome)
    -- Try ground items first
    if Workspace:FindFirstChild("Items") then
        for _, item in ipairs(Workspace.Items:GetChildren()) do
            if item.Name == nome then
                ReplicatedStorage.RemoteEvents.RequestConsumeItem:InvokeServer(item)
                return true -- Successfully ate from ground
            end
        end
    end
    
    -- Try Backpack items
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    if backpack then
        for _, item in ipairs(backpack:GetChildren()) do
            if item.Name == nome then
                ReplicatedStorage.RemoteEvents.RequestConsumeItem:InvokeServer(item)
                return true -- Successfully ate from backpack
            end
        end
    end
    
    -- Try custom Inventory items
    local inventory = LocalPlayer:FindFirstChild("Inventory")
    if inventory then
        for _, item in ipairs(inventory:GetChildren()) do
            if item.Name == nome then
                ReplicatedStorage.RemoteEvents.RequestConsumeItem:InvokeServer(item)
                return true -- Successfully ate from inventory
            end
        end
    end
    
    return false -- Nothing to eat
end

